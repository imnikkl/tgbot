# Required
BOT_TOKEN=replace-with-new-telegram-bot-token

# Optional: AI Provider (Gemini)
GEMINI_API_KEY=replace-with-gemini-key

# Optional: primary provider key (fallback provider works without it)
WEATHER_API_KEY=replace-with-openweather-key

# Required for coordinate encryption (AES-256 key, 32 bytes base64 urlsafe)
# Generate with:
# python -c "import secrets,base64; print(base64.urlsafe_b64encode(secrets.token_bytes(32)).decode().rstrip('='))"
LOCATION_ENC_KEY=replace-with-generated-key

DB_PATH=weather_bot.db
APP_TIMEZONE=Europe/Bucharest

CACHE_TTL_SECONDS=600
REQUEST_TIMEOUT_SECONDS=10
REQUEST_CONNECT_TIMEOUT_SECONDS=4
REQUEST_RETRIES=3
REQUEST_BACKOFF_SECONDS=0.8

ALERT_MORNING_HOUR=7
ALERT_MORNING_MINUTE=30
ALERT_EVENING_HOUR=19
ALERT_EVENING_MINUTE=30
SEVERE_INTERVAL_MINUTES=30
